{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bootstrap Project",
      "detail": "Scaffold a new react-ts project from the official SpacetimeDB template. Run once in an empty workspace.",
      "type": "shell",
      "command": "spacetime dev --template react-ts",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PATH": "/home/node/.local/bin:${env:PATH}" }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Start SpacetimeDB Server",
      "detail": "Start the local SpacetimeDB server.",
      "type": "shell",
      "command": "spacetime start",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PATH": "/home/node/.local/bin:${env:PATH}" }
      },
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "Start SpacetimeDB Dev",
      "detail": "Publish the multi-snake module and watch for changes.",
      "type": "shell",
      "command": "spacetime dev --project-path multi-snake/",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PATH": "/home/node/.local/bin:${env:PATH}" }
      },
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "Start Frontend",
      "detail": "Start the Vite dev server for the React client (port 5173).",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "Start Dev Tunnel",
      "detail": "Expose local ports 3000 (SpacetimeDB) and 5173 (Vite) to the internet via Dev Tunnels. Requires: devtunnel user login -g -d",
      "type": "shell",
      "command": "bash start-tunnel.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PATH": "/home/node/.local/bin:${env:PATH}" }
      },
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Start All",
      "detail": "Start SpacetimeDB server, dev watcher, and dev tunnel in parallel.",
      "dependsOn": [
        "Start SpacetimeDB Server",
        "Start SpacetimeDB Dev",
        "Start Dev Tunnel"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
