{
  "name": "SpacetimeDB Game",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-bookworm",
  "forwardPorts": [3000, 5173],
  "portsAttributes": {
    "3000": {
      "label": "SpacetimeDB",
      "onAutoForward": "silent"
    },
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowser"
    }
  },
  "remoteUser": "node",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:${containerEnv:HOME}/.local/bin:${containerEnv:HOME}/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "mhutchie.git-graph"
      ],
      "mcp": {
        "servers": {
          "io.github.upstash/context7": {
            "type": "stdio",
            "command": "npx",
            "args": ["@upstash/context7-mcp@1.0.31"],
            "gallery": "https://api.mcp.github.com",
            "version": "1.0.31"
          },
          "github/github-mcp-server": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/",
            "gallery": "https://api.mcp.github.com/v0/servers/ab12cd34-5678-90ef-1234-567890abcdef",
            "version": "0.13.0"
          }
        }
      },
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
